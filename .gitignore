# ─────────────────────────────────────────────
#  Secretos y credenciales — NUNCA al repo
# ─────────────────────────────────────────────
*.pem
*.key
*.crt
.env
**/db.env

# El compose.yaml REAL tiene passwords/IP → subí solo el .example
compose.yaml
!compose.yaml.example

# Las configs REALES pueden tener datos sensibles → subí solo los .example
config/*.conf
!config/*.conf.example

